---
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: {
		id: string;
		data: {
			title: string;
			description: string;
			pubDate: Date;
			categories: string[];
			author: string;
		};
	};
}

const { post } = Astro.props;
---

<a href={`/blog/${post.id}/`} class="no-underline text-inherit block group" title={`Đọc bài review chi tiết: ${post.data.title}`}>
	<article class="bg-card-bg border border-border-color rounded-xl p-4 md:p-6 sm:p-7 shadow-card-shadow flex flex-col transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-lg">
		<div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-2 mb-3 text-[14px] md:text-[18px] font-semibold font-title">
			<div class="flex flex-wrap gap-x-2 gap-y-1">
				{post.data.categories.map((cat) => (
					<span class={`uppercase tracking-wider text-${cat.toLowerCase()}`}>
						{cat}
					</span>
				))}
			</div>
			<div class="flex items-center gap-2 text-text-muted">
				<span class="text-text-primary font-medium">{post.data.author}</span>
				<span class="text-border-color">•</span>
				<span class="text-text-muted">
					<FormattedDate date={post.data.pubDate} />
				</span>
			</div>
		</div>
		
		<h3 class="text-[14px] md:text-[18px] font-bold mb-2 leading-snug text-text-primary group-hover:text-accent transition-colors duration-200 font-title">
			{post.data.title}
		</h3>
		<p class="text-[12px] md:text-[16px] text-text-secondary leading-relaxed font-body line-clamp-2">
			{post.data.description}
		</p>
	</article>
</a>
