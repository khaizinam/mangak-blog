---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-50 w-full border-b border-border-color bg-header-bg/85 backdrop-blur-md transition-all duration-300 px-6">
	<nav class="max-w-[1200px] mx-auto flex items-center justify-between h-18">
		<div class="flex items-center gap-2">
			<a href="/" class="no-underline flex items-center" title="Trang chủ MangaK - Chuyên trang review truyện tranh" aria-label="Trang chủ MangaK">
				<img src="/logo.png" alt="MangaK Logo - Kênh review truyện tranh Manga, Manhua, Manhwa" class="h-9 w-auto block" />
			</a>
		</div>
		<div class="flex gap-1 sm:gap-2">
			<HeaderLink href="/">Trang Chủ</HeaderLink>
			<HeaderLink href="/blog">Bài Review</HeaderLink>
			<HeaderLink href="/about">Giới Thiệu</HeaderLink>
		</div>
		<div class="flex items-center gap-4">
			<ThemeToggle />
		</div>
	</nav>
</header>
