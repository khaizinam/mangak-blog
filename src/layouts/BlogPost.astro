---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, rating, status, readLink, readSite, author, tags } = Astro.props;
---

<html lang="vi">
	<head>
		<BaseHead title={`${title} - Review Truyện Tranh MangaK`} description={description} />
		<style>
			.post-container {
				width: 100%;
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.post-header {
				margin-bottom: 2.5rem;
				text-align: center;
			}
			.category-wrapper {
				margin-bottom: 1rem;
			}
			.post-title {
				font-size: 2.5rem;
				font-weight: 800;
				color: var(--text-primary);
				line-height: 1.25;
				margin-bottom: 1.25rem;
			}
			
			/* Metadata Box */
			.metadata-box {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1rem;
				background-color: var(--card-bg);
				border: 1px solid var(--border-color);
				border-radius: 12px;
				padding: 1.25rem;
				margin-bottom: 2rem;
				text-align: left;
				box-shadow: var(--card-shadow);
			}
			.metadata-item {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.metadata-label {
				font-size: 0.8rem;
				text-transform: uppercase;
				color: var(--text-muted);
				font-weight: 600;
				font-family: var(--font-title);
				letter-spacing: 0.05em;
			}
			.metadata-value {
				font-weight: 600;
				color: var(--text-primary);
				font-size: 0.95rem;
			}
			.rating-value {
				color: #fbbf24; /* Yellow star */
				display: flex;
				align-items: center;
				gap: 0.25rem;
			}

			/* Banner Image */
			.hero-image-container {
				width: 100%;
				margin-bottom: 2.5rem;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: var(--card-shadow);
				background: linear-gradient(135deg, #1f2937, #111827);
				aspect-ratio: 16/9;
			}
			.hero-image-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			/* Prose content styling */
			.prose {
				color: var(--text-secondary);
				line-height: 1.8;
				font-size: 1.1rem;
			}
			.prose :global(h2), .prose :global(h3) {
				color: var(--text-primary);
				margin-top: 2rem;
				margin-bottom: 1rem;
			}
			.prose :global(p) {
				margin-bottom: 1.5rem;
			}
			.prose :global(ul), .prose :global(ol) {
				margin-bottom: 1.5rem;
				padding-left: 1.5rem;
			}
			.prose :global(li) {
				margin-bottom: 0.5rem;
			}
			.prose :global(strong) {
				color: var(--text-primary);
			}
			.prose :global(blockquote) {
				border-left: 4px solid var(--accent);
				background-color: var(--card-bg);
				padding: 1rem 1.5rem;
				border-radius: 0 8px 8px 0;
				margin: 1.5rem 0;
				font-style: italic;
				color: var(--text-primary);
			}

			/* Call to Action Backlink */
			.cta-box {
				background: var(--hero-bg);
				border: 1px solid var(--border-color);
				border-radius: 12px;
				padding: 1.5rem;
				text-align: center;
				margin: 2.5rem 0;
			}
			.cta-text {
				font-weight: 500;
				margin-bottom: 1rem;
				color: var(--text-primary);
			}
			.cta-box .btn {
				width: 100%;
				max-width: 320px;
			}

			@media (max-width: 640px) {
				.post-title {
					font-size: 1.8rem;
				}
				.metadata-box {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="post-container">
				<div class="post-header">
					<div class="category-wrapper">
						<span class={`badge badge-${category}`}>{category}</span>
					</div>
					<h1 class="post-title">{title}</h1>
					
					<!-- Metadata grid -->
					<div class="metadata-box">
						<div class="metadata-item">
							<span class="metadata-label">Ngày xuất bản</span>
							<span class="metadata-value"><FormattedDate date={pubDate} /></span>
						</div>
						<div class="metadata-item">
							<span class="metadata-label">Đánh giá</span>
							<span class="metadata-value rating-value">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
									<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
								</svg>
								{rating}
							</span>
						</div>
						<div class="metadata-item">
							<span class="metadata-label">Tình trạng truyện</span>
							<span class="metadata-value">{status}</span>
						</div>
						<div class="metadata-item">
							<span class="metadata-label">Người viết</span>
							<span class="metadata-value">{author}</span>
						</div>
					</div>
				</div>

				{heroImage && (
					<div class="hero-image-container">
						<img class="hero-image-img" src={heroImage} alt={title} />
					</div>
				)}

				<!-- Top CTA link (Backlink) -->
				<div class="cta-box">
					<p class="cta-text">🔥 Muốn đọc ngay bộ truyện này với chất lượng dịch tốt nhất?</p>
					<a href={readLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
						Đọc Ngay Tại {readSite} &rarr;
					</a>
				</div>

				<div class="prose">
					<slot />
				</div>

				<!-- Bottom CTA link (Backlink) -->
				<div class="cta-box">
					<p class="cta-text">Cảm ơn bạn đã đọc bài review của MangaK. Bấm vào link dưới đây để tới trang đọc bản dịch nhé!</p>
					<a href={readLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
						Đến Trang Đọc Truyện &rarr;
					</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
